{
	# Set this in .env or replace via env var; ACME email for Let's Encrypt
	email {$ACME_EMAIL:admin@example.com}
}

{$APP_DOMAIN:localhost} {
	encode gzip zstd

	# Limit request body size: 2 GiB. Adjust together with MAX_UPLOAD_BYTES.
	request_body {
		max_size 2GB
	}

	# Reverse proxy to the FastAPI app
	reverse_proxy app:8000 {
		# preserve original client info for slowapi / cookie security
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
		header_up X-Forwarded-Proto {scheme}
		flush_interval -1
	}

	# Helpful security headers
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options DENY
	}
}
